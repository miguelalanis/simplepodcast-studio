{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "store",
  "description": "Tauri plugin store para preferencias efímeras.",
  "windows": ["main"],
  "permissions": [
    "store:default",
    "store:allow-get",
    "store:allow-set",
    "store:allow-save",
    "store:allow-load",
    "store:allow-has",
    "store:allow-delete",
    "store:allow-clear",
    "store:allow-keys",
    "store:allow-values",
    "store:allow-entries",
    "store:allow-length"
  ]
}
