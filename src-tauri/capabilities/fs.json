{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "fs",
  "description": "Acceso al filesystem para podcasts clonados en ~/SimplePodcast/.",
  "windows": ["main"],
  "permissions": [
    {
      "identifier": "fs:scope",
      "allow": [
        { "path": "$HOME/SimplePodcast/**" }
      ]
    },
    "fs:allow-read-text-file",
    "fs:allow-read-dir",
    "fs:allow-exists",
    {
      "identifier": "fs:allow-write-text-file",
      "allow": [
        { "path": "$HOME/SimplePodcast/**" }
      ]
    },
    {
      "identifier": "fs:allow-mkdir",
      "allow": [
        { "path": "$HOME/SimplePodcast/**" }
      ]
    },
    {
      "identifier": "fs:allow-remove",
      "allow": [
        { "path": "$HOME/SimplePodcast/**" }
      ]
    },
    {
      "identifier": "fs:allow-rename",
      "allow": [
        {
          "oldPath": "$HOME/SimplePodcast/**",
          "newPath": "$HOME/SimplePodcast/**"
        }
      ]
    }
  ]
}
